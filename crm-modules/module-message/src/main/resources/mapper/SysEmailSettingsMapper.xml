<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crm.message.mapper.SysEmailSettingsMapper">

    <resultMap id="BaseResultMap" type="com.crm.message.domain.entity.SysEmailSettings">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="email_address" property="emailAddress"/>
        <result column="display_name" property="displayName"/>
        <result column="smtp_host" property="smtpHost"/>
        <result column="smtp_port" property="smtpPort"/>
        <result column="smtp_username" property="smtpUsername"/>
        <result column="smtp_password" property="smtpPassword"/>
        <result column="smtp_encryption" property="smtpEncryption"/>
        <result column="smtp_auth" property="smtpAuth"/>
        <result column="imap_host" property="imapHost"/>
        <result column="imap_port" property="imapPort"/>
        <result column="imap_username" property="imapUsername"/>
        <result column="imap_password" property="imapPassword"/>
        <result column="imap_encryption" property="imapEncryption"/>
        <result column="enabled" property="enabled"/>
        <result column="is_default" property="isDefault"/>
        <result column="sync_interval" property="syncInterval"/>
        <result column="keep_server_copy" property="keepServerCopy"/>
        <result column="email_signature" property="emailSignature"/>
        <result column="page_size" property="pageSize"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, user_id, email_address, display_name,
        smtp_host, smtp_port, smtp_username, smtp_password, smtp_encryption, smtp_auth,
        imap_host, imap_port, imap_username, imap_password, imap_encryption,
        enabled, is_default, sync_interval, keep_server_copy, email_signature, page_size,
        created_time, updated_time, deleted
    </sql>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_email_settings
        WHERE user_id = #{userId}
          AND deleted = 0
        ORDER BY is_default DESC, created_time ASC
    </select>

    <select id="selectDefaultByUserId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_email_settings
        WHERE user_id = #{userId}
          AND is_default = 1
          AND deleted = 0
        LIMIT 1
    </select>

    <select id="selectByEmailAddress" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM sys_email_settings
        WHERE email_address = #{emailAddress}
          AND deleted = 0
        LIMIT 1
    </select>

</mapper>
