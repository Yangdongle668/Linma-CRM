<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.crm.customer.mapper.CrmCustomerTagMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.crm.customer.domain.entity.CrmCustomerTag">
        <id column="customer_id" property="customerId"/>
        <id column="tag_id" property="tagId"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <!-- 根据客户ID获取标签ID列表 -->
    <select id="selectTagIdsByCustomerId" resultType="java.lang.Long">
        SELECT tag_id FROM crm_customer_tag
        WHERE customer_id = #{customerId}
    </select>

    <!-- 删除客户的所有标签关联 -->
    <delete id="deleteByCustomerId">
        DELETE FROM crm_customer_tag
        WHERE customer_id = #{customerId}
    </delete>

    <!-- 批量插入客户标签关联 -->
    <insert id="batchInsert">
        INSERT INTO crm_customer_tag (customer_id, tag_id, created_time)
        VALUES
        <foreach collection="tagIds" item="tagId" separator=",">
            (#{customerId}, #{tagId}, NOW())
        </foreach>
    </insert>

</mapper>
